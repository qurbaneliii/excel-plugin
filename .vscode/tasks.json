{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: create venv",
      "type": "shell",
      "command": "Set-Location backend; python -m venv .venv",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: install requirements",
      "type": "shell",
      "command": "Set-Location backend; .\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run dev server",
      "type": "shell",
      "command": "Set-Location backend; .\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: run tests",
      "type": "shell",
      "command": "Set-Location backend; .\\.venv\\Scripts\\python.exe -m pytest -q",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: compile check",
      "type": "shell",
      "command": "Set-Location backend; .\\.venv\\Scripts\\python.exe -m compileall app",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: install dependencies",
      "type": "shell",
      "command": "Set-Location frontend; npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: run Excel add-in dev server",
      "type": "shell",
      "command": "Set-Location frontend; npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "Set-Location frontend; npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
